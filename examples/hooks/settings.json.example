{
  "hooks": {
    "Bash": {
      "pre": [
        {
          "description": "Block git force push (all variants)",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"push.*(--force|-f)\") | not'"
        },
        {
          "description": "Block destructive git commands",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"git (reset --hard|clean -f|checkout \\\\.|restore \\\\.)\") | not'"
        },
        {
          "description": "Block deletion of protected directories",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"rm .*(infrastructure|deploy|config)/\") | not'"
        },
        {
          "description": "Block commands that might leak secrets",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(cat|echo|curl).*(env|credentials|secret|token)\") | not'"
        }
      ]
    },
    "Write": {
      "pre": [
        {
          "description": "Block writes to secret files",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"\\\\.(env|pem|key)$\") | not'"
        }
      ]
    },
    "Edit": {
      "pre": [
        {
          "description": "Block edits to CI/CD pipelines",
          "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"\\\\.github/workflows/\") | not'"
        }
      ]
    }
  }
}
