{
  "description": "Infrastructure and platform work with strict guardrails for expensive mistakes.",
  "intendedUse": "Terraform, Kubernetes, Azure/AWS infrastructure work. Inherits the minimal default baseline, then adds broader git/security, cloud, CI/CD, and platform-specific safety hooks.",
  "layers": ["hooks", "permissions", "sub-agents"],
  "fragments": {
    "hooks": [
      "git/destructive.json",
      "git/prod-branch.json",
      "security/rm-safety.json",
      "security/secret-protection.json",
      "security/supply-chain.json",
      "security/credential-files.json",
      "security/token-echo.json",
      "security/env-leak.json",
      "terraform/safety.json",
      "kubernetes/safety.json",
      "kubernetes/prod-context.json",
      "aws/safety.json",
      "ci-cd/protection.json",
      "ci-cd/make-deploy.json",
      "gh/protected-merge.json",
      "gh/workflow-dispatch.json",
      "gh/release-publish.json"
    ],
    "permissions": [
      "presets/standard-dev.json"
    ],
    "sub-agents": [
      "readonly-explorer.json",
      "release-reviewer.json"
    ]
  }
}
