{
  "description": "Go backend/app development with safety guardrails and low friction.",
  "intendedUse": "Normal Go application and backend development. Safe defaults with auto-allowed test and lint commands.",
  "layers": ["hooks", "permissions", "sub-agents"],
  "fragments": {
    "hooks": [
      "git/safety.json",
      "git/prod-branch.json",
      "security/rm-safety.json",
      "security/secret-protection.json",
      "security/supply-chain.json",
      "security/credential-files.json",
      "security/token-echo.json",
      "packages/publish.json"
    ],
    "permissions": [
      "presets/standard-dev.json"
    ],
    "sub-agents": [
      "reviewer.json",
      "readonly-explorer.json"
    ]
  }
}
