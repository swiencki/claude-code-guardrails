{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"aws\\\\s+.*(delete-|terminate-|remove-|destroy-|drop-)|aws\\\\s+s3\\\\s+(rm|rb)\\\\s\") | not'",
            "statusMessage": "Checking for destructive AWS CLI commands",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"--mode\\\\s+Complete\") | not'",
            "statusMessage": "Checking for az deployment --mode Complete",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"rm .*(infrastructure|deploy|config)/\") | not'",
            "statusMessage": "Checking for protected directory deletion",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"push.*(--force|-f)\") | not'",
            "statusMessage": "Checking for git force push",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"git (reset --hard|clean -f|checkout \\\\.|restore \\\\.)\") | not'",
            "statusMessage": "Checking for destructive git commands",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"kubectl\\\\s+(delete|drain|exec)\") | not'",
            "statusMessage": "Checking for destructive kubectl commands",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(npm publish|yarn publish|pip.*upload|twine upload|cargo publish|gem push)\") | not'",
            "statusMessage": "Checking for package publish commands",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"rm\\\\s+(-[a-zA-Z]*\\\\s+)*(/$|/\\\\s|~|\\\\$HOME|\\\\*|/(etc|usr|var|home|opt|root|bin|sbin|lib|boot|dev|proc|sys|srv|run|mnt|media)(/|\\\\s|$))\") | not'",
            "statusMessage": "Checking for dangerous rm commands",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(cat|bat|less|more|head|tail|vim|nano|curl|wget).*(/\\\\.env|/\\\\.ssh/|/\\\\.aws/|/\\\\.kube/config|/\\\\.gnupg/|\\\\.pem|\\\\.key|credentials)\") | not'",
            "statusMessage": "Checking for secret/credential access",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(curl|wget).*\\\\|\\\\s*(bash|sh|zsh|python|python3|perl|ruby|node)\") | not'",
            "statusMessage": "Checking for piped remote execution",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"terraform\\\\s+(destroy|apply)\") | not'",
            "statusMessage": "Checking for terraform destroy/apply",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"\\\\.github/workflows/\") | not'",
            "statusMessage": "Checking for CI/CD pipeline edits",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"(/\\\\.env|\\\\.pem|\\\\.key|credentials|/\\\\.ssh/|/\\\\.aws/|/\\\\.kube/config|/\\\\.gnupg/)\") | not'",
            "statusMessage": "Checking for secret file reads",
            "type": "command"
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"\\\\.github/workflows/\") | not'",
            "statusMessage": "Checking for CI/CD pipeline writes",
            "type": "command"
          },
          {
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"(/\\\\.env|\\\\.pem|\\\\.key|credentials|/\\\\.ssh/|/\\\\.aws/|/\\\\.kube/config|/\\\\.gnupg/)\") | not'",
            "statusMessage": "Checking for secret file writes",
            "type": "command"
          }
        ],
        "matcher": "Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git branch)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git status)",
      "Bash(go test ./...)",
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Glob",
      "Grep",
      "Read"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(git push *)",
      "Bash(git push --force*)",
      "Bash(git reset *)",
      "Bash(git reset --hard*)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(wget *)",
      "Edit",
      "Write"
    ]
  }
}
