{
  "description": "Blocks dangerous Azure CLI operations like --mode Complete deployments.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.tool_input.command // \"\" | test(\"--mode\\\\s+Complete\") | not' >/dev/null",
            "statusMessage": "Checking for az deployment --mode Complete"
          }
        ]
      }
    ]
  }
}
