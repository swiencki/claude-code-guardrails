{
  "description": "Prevents reading, writing, or leaking secret files and credential paths.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(cat|bat|less|more|head|tail|grep|vim|nano|echo|curl|wget).*(\\\\.env|credentials|secret|token|\\\\.pem|\\\\.key|\\\\.ssh/|\\\\.aws/|\\\\.kube/config|\\\\.gnupg/)\") | not'",
            "statusMessage": "Checking for secret/credential access"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"(\\\\.env|\\\\.pem|\\\\.key|credentials|/\\\\.ssh/|/\\\\.aws/|/\\\\.kube/config|/\\\\.gnupg/)\" ) | not'",
            "statusMessage": "Checking for secret file writes"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"(\\\\.env|\\\\.pem|\\\\.key|credentials|/\\\\.ssh/|/\\\\.aws/|/\\\\.kube/config|/\\\\.gnupg/)\") | not'",
            "statusMessage": "Checking for secret file reads"
          }
        ]
      }
    ]
  }
}
