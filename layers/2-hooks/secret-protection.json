{
  "description": "Prevents reading, writing, or leaking secret files (.env, .pem, .key, credentials).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.command | test(\"(cat|echo|curl).*(env|credentials|secret|token)\") | not'",
            "statusMessage": "Checking for secret leaks"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -e '.file_path | test(\"\\\\.(env|pem|key)$\") | not'",
            "statusMessage": "Checking for secret file writes"
          }
        ]
      }
    ]
  }
}
